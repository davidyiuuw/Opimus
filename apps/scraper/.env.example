# Supabase — same project as apps/api, use the service role key for writes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scraper behaviour
NODE_ENV=development

# Polite delay between country fetches (ms) — keeps us under CDC/State Dept rate limits
FETCH_DELAY_MS=2000

# node-cron schedule (default: daily at 02:00 UTC)
CRON_SCHEDULE=0 2 * * *
