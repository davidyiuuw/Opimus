# Supabase (get from supabase.com project settings)
# Note: EXPO_PUBLIC_ prefix makes these available in the app bundle
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL
EXPO_PUBLIC_API_URL=http://localhost:3000

# Pexels API (free at pexels.com/api — used for home screen video backgrounds)
EXPO_PUBLIC_PEXELS_API_KEY=your-pexels-api-key
