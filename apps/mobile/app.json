{
  "expo": {
    "name": "Opimus",
    "slug": "opimus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F4C81"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.opimus.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.opimus.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Opimus to access your photos to upload vaccination documents."
        }
      ],
      "expo-apple-authentication"
    ],
    "scheme": "opimus",
    "experiments": {
      "typedRoutes": false
    }
  }
}
